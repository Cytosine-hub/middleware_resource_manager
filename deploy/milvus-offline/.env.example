MILVUS_VERSION=v2.3.4
ETCD_VERSION=v3.5.5
MINIO_VERSION=RELEASE.2023-03-20T20-16-18Z

MILVUS_DATA_DIR=/data/milvus
MILVUS_PORT=19530
MILVUS_WEBUI_PORT=9091
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Milvus 2.3.x standalone 默认按 minioadmin/minioadmin 访问 MinIO。
# 本部署包将 MinIO 端口默认绑定 127.0.0.1，生产环境不要对外暴露 9000/9001。
# 如需改账号密码，必须同时清空已有 MinIO 数据目录后重新初始化。
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# 外网制包阶段使用。生产服务器不需要配置这些。
# Mac Apple Silicon 给 x86_64 Linux 服务器制包时建议保留 linux/amd64。
DOCKER_PLATFORM=linux/amd64
DOCKER_PULL_RETRIES=3

# Docker Hub 访问不稳定时配置企业镜像代理，例如：
# DOCKER_HUB_MIRROR_PREFIX=registry.example.com/dockerhub
# 拉取 milvusdb/milvus:v2.3.4 失败时会尝试：
# registry.example.com/dockerhub/milvusdb/milvus:v2.3.4
DOCKER_HUB_MIRROR_PREFIX=
