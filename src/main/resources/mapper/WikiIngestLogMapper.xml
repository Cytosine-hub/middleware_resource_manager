<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.middleware.manager.wiki.repository.WikiIngestLogMapper">

    <resultMap id="wikiIngestLogResultMap" type="WikiIngestLog">
        <id property="id" column="id"/>
        <result property="sourceId" column="source_id"/>
        <result property="operatorId" column="operator_id"/>
        <result property="pagesCreated" column="pages_created"/>
        <result property="pagesUpdated" column="pages_updated"/>
        <result property="linksCreated" column="links_created"/>
        <result property="contradictionsFound" column="contradictions_found"/>
        <result property="llmModel" column="llm_model"/>
        <result property="llmTokensUsed" column="llm_tokens_used"/>
        <result property="durationMs" column="duration_ms"/>
        <result property="status" column="status"/>
        <result property="errorDetail" column="error_detail"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <select id="findBySourceId" resultMap="wikiIngestLogResultMap">
        SELECT * FROM wiki_ingest_log WHERE source_id = #{sourceId} ORDER BY created_at DESC
    </select>

    <select id="findRecent" resultMap="wikiIngestLogResultMap">
        SELECT * FROM wiki_ingest_log ORDER BY created_at DESC LIMIT #{limit}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO wiki_ingest_log (source_id, operator_id, pages_created, pages_updated, links_created, contradictions_found, llm_model, llm_tokens_used, duration_ms, status, error_detail)
        VALUES (#{sourceId}, #{operatorId}, #{pagesCreated}, #{pagesUpdated}, #{linksCreated}, #{contradictionsFound}, #{llmModel}, #{llmTokensUsed}, #{durationMs}, #{status}, #{errorDetail})
    </insert>

    <delete id="deleteBySourceId">
        DELETE FROM wiki_ingest_log WHERE source_id = #{sourceId}
    </delete>

</mapper>
